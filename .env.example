# Supabase connection
# Get these from your Supabase project: Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Platform domain for subdomain-based tenant resolution
# e.g., "myplatform.com" — tenants access via slug.myplatform.com
# Leave empty for single-tenant mode (default org used)
PLATFORM_DOMAIN=

# Vercel API integration for custom domain management (optional)
# Required only if you want automated custom domain provisioning
VERCEL_API_TOKEN=     # Personal access token or team token (Settings → Tokens)
VERCEL_PROJECT_ID=    # Project ID (Project Settings → General → Project ID)

# Cron job secret for scheduled tasks
# Used by /api/cron/* endpoints to verify requests
CRON_SECRET=

# Google OAuth (optional)
# If you want "Sign in with Google", configure it in the Supabase dashboard:
#   Authentication > Providers > Google
# You will need a Google Cloud OAuth 2.0 Client ID and Client Secret.
# No additional env vars are required in this file — credentials are stored
# in Supabase, not in the app.
#
# Required Supabase settings:
#   1. Supabase Dashboard > Authentication > Providers > Google
#      → Enable Google, paste your Client ID and Secret
#   2. Supabase Dashboard > Authentication > URL Configuration
#      → Add your app's callback URL to "Redirect URLs":
#        http://localhost:3000/api/auth/callback   (local dev)
#        https://your-app.vercel.app/api/auth/callback  (production)
#
# To obtain Google credentials:
#   https://console.cloud.google.com/apis/credentials
#   Create an OAuth 2.0 Client ID (Web application)
#   Add Authorized redirect URI:
#     https://your-project.supabase.co/auth/v1/callback
